{
  "compilerOptions": {
    "jsx": "react",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/*"],
      "@presentation/*": ["src/presentation/*"],
    }
  },
  "extends": "@react-native/typescript-config/tsconfig.json"
}
